# Copy this file to `.env` and fill in your keys.
# Required for the semantic RAG (Gemini embeddings) and chat responses:
GEMINI_API_KEY=your-gemini-api-key-here

# Optional fallback LLM:
OPENAI_API_KEY=

# App config (defaults shown):
FLASK_PORT=5000
CORS_ORIGIN=http://localhost:3000
DEBUG_AI=true

# Database:
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=healthcare

# Accounts & auth (patient / doctor / admin):
JWT_SECRET=change-this-to-a-long-random-string
JWT_TTL_HOURS=168
ADMIN_EMAIL=admin@auravia.health
ADMIN_PASSWORD=admin123

# RAG tuning (local numpy engine — fallback):
RAG_RELEVANCE_THRESHOLD=0.78
RAG_EMBED_MODEL=models/gemini-embedding-001

# Vector DB (MongoDB Atlas Vector Search) — primary retrieval:
RAG_EMBED_DIM=768               # gemini-embedding-001 output dims (768/1536/3072)
RAG_VECTOR_THRESHOLD=0.72       # Atlas cosine vectorSearchScore cutoff (0-1)
# Embedding batches respect the free-tier ~100 req/min quota:
RAG_EMBED_BATCH_SIZE=80
RAG_EMBED_BATCH_PAUSE=61
# Rebuild the vector KB:  python3 ingest_dataset.py
# Optional dataset sizes:  DISEASES_LIMIT=400  MEDQUAD_LIMIT=400
