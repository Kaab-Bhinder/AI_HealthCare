# Copy this file to `.env` and fill in your keys.
# Required for the semantic RAG (Gemini embeddings) and chat responses:
GEMINI_API_KEY=your-gemini-api-key-here

# Optional fallback LLM:
OPENAI_API_KEY=

# App config (defaults shown):
FLASK_PORT=5000
CORS_ORIGIN=http://localhost:3000
ADMIN_PASSWORD=change-me
DEBUG_AI=true

# RAG tuning: cosine-similarity cutoff below which a document is treated as
# irrelevant (0.0-1.0). Raise it for stricter matching, lower it for broader.
RAG_RELEVANCE_THRESHOLD=0.62
