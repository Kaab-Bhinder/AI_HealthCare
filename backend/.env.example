# Copy this file to `.env` and fill in your keys.
# Required for the semantic RAG (Gemini embeddings) and chat responses:
GEMINI_API_KEY=your-gemini-api-key-here

# Optional fallback LLM:
OPENAI_API_KEY=

# App config (defaults shown):
FLASK_PORT=5000
CORS_ORIGIN=http://localhost:3000
ADMIN_PASSWORD=change-me
DEBUG_AI=true

# RAG tuning:
# Cosine-similarity cutoff below which a document is treated as irrelevant
# (0.0-1.0). Real medical matches score ~0.80+, off-topic queries ~0.74, so
# 0.78 cleanly rejects unrelated questions. Raise for stricter matching.
RAG_RELEVANCE_THRESHOLD=0.78
# Embedding model (must support embedContent on your API tier):
RAG_EMBED_MODEL=models/gemini-embedding-001
# One-time index build batching to respect free-tier ~100 req/min quota:
RAG_EMBED_BATCH_SIZE=80
RAG_EMBED_BATCH_PAUSE=61
